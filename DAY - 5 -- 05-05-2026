// Problem -- 1 
// Pattern printing

#include <iostream>
using namespace std;

int main() {  
    
    // Upper triangle 
    for(int i = 1; i <= 10; i++){
        for(int j = 1; j <= i; j++){
            cout << "*";
        }
        cout <<"\n";
    }    
    
    // Lower triangle
    for(int i = 10-1; i>=1; i--){
            for(int j=1; j<=i; j++){
                cout << "*";
            }
            cout << "\n";
    }
}

