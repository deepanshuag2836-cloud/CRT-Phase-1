// 1.5 -- Hybrid Inheritance -- Diamond problem solution -- virtual base class

#include <iostream>
using namespace std;

class A {
    public:
    void print() {
        cout <<"Hi there...";
    }
};

class B : virtual public A {
    //NO LOGIC
};

class C : virtual public A {
    //NO LOGIC;
};

class D : public B , public C{
    //NO LOGIC
};

int main() {
    D obj1;
    obj1.print();
}

